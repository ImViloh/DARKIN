{
  "name": "darkin",
  "version": "1.0.0",
  "description": "DARKIN launcher for the DARKIN web game",
  "homepage": "https://example.com/darkin",
  "private": true,
  "main": "darkin.js",
  "author": {
    "name": "viloh",
    "email": "imviloh@gmail.com"
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:local": "electron-builder -p never",
    "dist:linux": "electron-builder -p never --linux",
    "dist:winux": "electron-builder -p never --linux --win",
    "dist:win": "electron-builder -p never --win"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "animate.css": "^4.1.1",
    "bootstrap": "^5.3.3",
    "electron-updater": "^6.8.3",
    "jquery": "^4.0.0"
  },
  "build": {
    "appId": "com.viloh.darkin",
    "icon": "DARKIN_CLEAR.png",
    "productName": "DARKIN",
    "directories": {
      "output": "dist"
    },
    "files": [
      "darkin.js",
      "CLIENT/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Game",
      "maintainer": "viloh <you@example.com>"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "YOUR_GITHUB_USERNAME",
        "repo": "darkin",
        "releaseType": "draft"
      }
    ]
  }
}
